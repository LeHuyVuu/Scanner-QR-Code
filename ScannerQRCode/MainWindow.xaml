<Window x:Class="BT3_Day2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QR Code Scanner" Height="450" Width="800">
    <Grid>
        <Image Name="imgWebcam" Width="640" Height="480"/>
        <Button Content="Start Scanning" Click="btnStart_Click" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10"/>
        <Button Content="Test QR Code" Click="btnTestQRCode_Click" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10"/>
    </Grid>
</Window>
